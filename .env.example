# ─── Branding ──────────────────────────────────────────────────────────────
BRAND_NAME=Asistente Acme
BRAND_TAGLINE=Sistema de seguimiento de proyectos
PRIMARY_COLOR=#000000
ACCENT_COLOR=#3b82f6
LOGO_URL=

# ─── Contacto ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@acme.com
MAIL_FROM_NAME=Asistente Acme
MAIL_FROM_ADDRESS=asistente@acme.com

# ─── Vocabulario del negocio ───────────────────────────────────────────────
# Cómo se llaman las cosas en este negocio. Aparecen en mails, dashboard, push.
INPUT_SINGULAR=archivo
INPUT_PLURAL=archivos
OUTPUT_SINGULAR=entrega
OUTPUT_PLURAL=entregas
ASSIGNEE_SINGULAR=responsable
ASSIGNEE_PLURAL=responsables
PROJECT_SINGULAR=proyecto
PROJECT_PLURAL=proyectos
ACTION_VERB=completar
ACTION_DONE=completado

# ─── Drive ─────────────────────────────────────────────────────────────────
INPUT_FOLDER_NAMES=material,raw,crudos,input
INPUT_EXTS=.mp4,.mov,.avi,.mkv,.m4v,.webm

# ─── Sheet de matching (proyecto → responsable) ────────────────────────────
SHEET_ID=
SHEET_TAB=Sheet1
SHEET_HEADER_ROW=1
SHEET_COL_PROJECT=cliente
SHEET_COL_ASSIGNEE=responsable

# ─── Deploy ────────────────────────────────────────────────────────────────
DASHBOARD_URL=https://asistente-acme.vercel.app
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_REPO_FULL=

# ─── Secrets (NO commitear) ────────────────────────────────────────────────
DASHBOARD_SECRET=
VAPID_SUBJECT=mailto:admin@acme.com
VAPID_PRIVATE_KEY=
GITHUB_PAT=

# ─── OAuth (sale de python3 auth.py) ───────────────────────────────────────
OAUTH_REFRESH_TOKEN=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ─── Modo prueba (opcional) ────────────────────────────────────────────────
# Si seteás TEST_EMAIL, todos los mails van a esa dirección en vez de a los
# responsables reales. Útil para QA sin spammear al equipo.
TEST_EMAIL=
